# ─── Supabase PostgreSQL Connection ───────────────────────────────────────────
# Get this from: Supabase Dashboard → Project Settings → Database → Connection String → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres?sslmode=require

# ─── Flask Secret Key ─────────────────────────────────────────────────────────
FRESHMILK_SECRET=replace-this-with-a-secure-random-string

# ─── Email (for OTP Password Reset) ───────────────────────────────────────────
MAIL_SENDER=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
